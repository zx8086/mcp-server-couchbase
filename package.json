{
  "name": "mcp-couchbase",
  "version": "0.2.0",
  "description": "Couchbase MCP Server - The Developer Data Platform for Critical Applications in Our AI World (TypeScript/Bun Version)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "src/index.ts",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "start": "bun run dist/index.js --transport stdio",
    "start:sse": "bun run dist/index.js --transport sse",
    "dev": "bun run src/index.ts --transport stdio",
    "dev:sse": "bun run src/index.ts --transport sse",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "couchbase": "^4.4.5",
    "dotenv": "^16.5.0",
    "winston": "^3.17.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/bun": "^1.2.12",
    "bun-types": "^1.2.12",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zx8086/mcp-server-couchbase"
  }
}
